rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "marandianil31@gmail.com" && request.auth.token.email_verified == true);
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['coins', 'displayName', 'photoURL', 'lastDailyReward', 'isVip']) || isAdmin());
    }

    match /campaigns/{campaignId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.creatorId == request.auth.uid;
      allow update: if isAuthenticated(); // Allow updating currentViews when someone watches
      allow delete: if isAuthenticated() && resource.data.creatorId == request.auth.uid;
    }

    match /viewLogs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }
  }
}
